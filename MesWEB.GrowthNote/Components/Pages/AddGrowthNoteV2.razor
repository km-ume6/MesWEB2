    private void CalculatePelletSum()
    {
        int sum = (newItem.Pellet1Feed ?? 0) + (newItem.Pellet2Feed ?? 0) + (newItem.Pellet3Feed ?? 0);
        newItem.PelletFeed = sum;
    }

    private void CalculateCulletSum()
    {
        int sum = (newItem.Cullet1Feed ?? 0) + (newItem.Cullet2Feed ?? 0) + (newItem.Cullet3Feed ?? 0);
        newItem.CulletFeed = sum;
    }

