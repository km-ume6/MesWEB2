    private async Task LoadDecimalPositionsByMachineName(string? machineName)
    {
        var normalizedMachineName = NormalizeFileName(machineName);
        if (string.IsNullOrWhiteSpace(normalizedMachineName))
        {
            Array.Fill(importDecimalPositions, 0);
            return;
        }

        var store = await ReadSettingsStoreAsync();
        var savedSetting = FindSettingByMachineName(store, normalizedMachineName);
        var settings = NormalizeColumnSettings(savedSetting?.ColumnSettings);

        for (var i = 0; i < ImportSettingCount; i++)
        {
            importDecimalPositions[i] = Math.Max(0, settings[i].DecimalPosition);
        }

        StateHasChanged();
    }

    private async Task<SettingsStore> ReadSettingsStoreAsync()
    {
        var settingsPath = GetSettingsFilePath();
        if (!File.Exists(settingsPath))
        {
            return new SettingsStore();
        }

        await using var stream = new FileStream(settingsPath, FileMode.Open, FileAccess.Read, FileShare.Read, 4096, useAsync: true);
        var store = await JsonSerializer.DeserializeAsync<SettingsStore>(stream) ?? new SettingsStore();

        foreach (var item in store.Files)
        {
            item.FileName = NormalizeFileName(item.FileName);
            item.ColumnSettings = NormalizeColumnSettings(item.ColumnSettings);
        }

        return store;
    }

    private string GetSettingsFilePath()
    {
        var primary = Path.Combine(HostEnvironment.ContentRootPath, SettingsDirectoryName, SettingsFileName);
        if (File.Exists(primary))
        {
            return primary;
        }

        var parent = Directory.GetParent(HostEnvironment.ContentRootPath)?.FullName;
        if (!string.IsNullOrWhiteSpace(parent))
        {
            var sibling = Path.Combine(parent, "MesWEB", SettingsDirectoryName, SettingsFileName);
            if (File.Exists(sibling))
            {
                return sibling;
            }
        }

        return primary;
    }

    private static SavedFileSetting? FindSettingByMachineName(SettingsStore store, string machineName)
    {
        if (store.Files.Count == 0)
        {
            return null;
        }

        var normalizedMachineName = NormalizeFileName(machineName);
        if (string.IsNullOrWhiteSpace(normalizedMachineName))
        {
            return null;
        }

        var candidates = new List<string> { normalizedMachineName };
        if (!normalizedMachineName.Contains('.'))
        {
            candidates.Add($"{normalizedMachineName}.CSV");
        }

        return store.Files.FirstOrDefault(x =>
            candidates.Any(c => string.Equals(NormalizeFileName(x.FileName), c, StringComparison.OrdinalIgnoreCase)));
    }

    private static List<ColumnSetting> NormalizeColumnSettings(IEnumerable<ColumnSetting>? source)
    {
        var normalized = source?
            .Take(ImportSettingCount)
            .Select(x => new ColumnSetting
            {
                ColumnNumber = x.ColumnNumber > 0 ? x.ColumnNumber : 1,
                DecimalPosition = x.DecimalPosition >= 0 ? x.DecimalPosition : 0
            })
            .ToList() ?? [];

        while (normalized.Count < ImportSettingCount)
        {
            normalized.Add(new ColumnSetting { ColumnNumber = normalized.Count + 1, DecimalPosition = 0 });
        }

        return normalized;
    }

    private static string NormalizeFileName(string? fileName)
    {
        if (string.IsNullOrWhiteSpace(fileName))
        {
            return string.Empty;
        }

        return Path.GetFileName(fileName.Trim());
    }

    private string FormatImportedValue(float? value, int settingIndex)
    {
        if (!value.HasValue)
        {
            return string.Empty;
        }

        var digits = settingIndex >= 0 && settingIndex < importDecimalPositions.Length
            ? Math.Clamp(importDecimalPositions[settingIndex], 0, 6)
            : 0;

        return value.Value.ToString($"F{digits}", CultureInfo.InvariantCulture);
    }

    private static float? ParseDotDecimalOrNull(string? text)
    {
        var value = text?.Trim();
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return float.TryParse(value, NumberStyles.Float, CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : null;
    }

