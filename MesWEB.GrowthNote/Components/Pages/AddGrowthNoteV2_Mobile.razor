    private async Task LoadExistingData()
    {
        using var db = DbFactory.CreateDbContext();

        var allNotes = await db.GrowthNotes
            .Include(n => n.Parameters)
            .Include(n => n.Insulation)
            .ToListAsync();

        existingOperators = allNotes.Where(n => !string.IsNullOrWhiteSpace(n.Operator))
            .Select(n => n.Operator!).Distinct().OrderBy(x => x).ToList();

        existingMachines = allNotes.Where(n => !string.IsNullOrWhiteSpace(n.MachineName))
            .Select(n => n.MachineName!).Distinct().OrderBy(x => x).ToList();

        existingDopants = allNotes.Where(n => !string.IsNullOrWhiteSpace(n.Dopants))
            .Select(n => n.Dopants!).Distinct().OrderBy(x => x).ToList();

        existingCrystalLots = allNotes.Where(n => !string.IsNullOrWhiteSpace(n.CrystalLot))
            .Select(n => n.CrystalLot!).Distinct().OrderBy(x => x).ToList();

        existingPelletLots = allNotes.SelectMany(n => new[] { n.PelletLot1, n.PelletLot2, n.PelletLot3 })
            .Where(lot => !string.IsNullOrWhiteSpace(lot)).Select(lot => lot!).Distinct().OrderBy(x => x).ToList();

        existingCulletLots = allNotes.SelectMany(n => new[] { n.CulletLot1, n.CulletLot2, n.CulletLot3 })
            .Where(lot => !string.IsNullOrWhiteSpace(lot)).Select(lot => lot!).Distinct().OrderBy(x => x).ToList();

        existingCrucibles = allNotes.Where(n => !string.IsNullOrWhiteSpace(n.CrucibleName))
            .Select(n => n.CrucibleName!).Distinct().OrderBy(x => x).ToList();

        existingInsideInsulation = allNotes.Where(n => n.Insulation != null && !string.IsNullOrWhiteSpace(n.Insulation.InsideInsulationComposition))
            .Select(n => n.Insulation!.InsideInsulationComposition!).Distinct().OrderBy(x => x).ToList();

        existingBottomInsulation = allNotes.Where(n => n.Insulation != null && !string.IsNullOrWhiteSpace(n.Insulation.BottomInsulationComposition))
            .Select(n => n.Insulation!.BottomInsulationComposition!).Distinct().OrderBy(x => x).ToList();

        existingFurnaceConditions = allNotes
            .Where(n => n.Insulation != null)
            .SelectMany(n => new[] { n.Insulation!.FurnaceCondition1, n.Insulation.FurnaceCondition2 })
            .Where(cond => !string.IsNullOrWhiteSpace(cond)).Select(cond => cond!).Distinct().OrderBy(x => x).ToList();

        existingRingPositions = allNotes.Where(n => n.Parameters != null && !string.IsNullOrWhiteSpace(n.Parameters.RingHeightPosition))
            .Select(n => n.Parameters!.RingHeightPosition!).Distinct().OrderBy(x => x).ToList();

        existingDisks = allNotes.Where(n => n.Insulation != null && !string.IsNullOrWhiteSpace(n.Insulation.UsingDisk))
            .Select(n => n.Insulation!.UsingDisk!).Distinct().OrderBy(x => x).ToList();

        existingGravityCenters = allNotes.Where(n => n.Parameters != null && !string.IsNullOrWhiteSpace(n.Parameters.GravityCenterWC))
            .Select(n => n.Parameters!.GravityCenterWC!).Distinct().OrderBy(x => x).ToList();

        existingHeightPositions = allNotes.Where(n => n.Parameters != null && !string.IsNullOrWhiteSpace(n.Parameters.HeightPositionWC))
            .Select(n => n.Parameters!.HeightPositionWC!).Distinct().OrderBy(x => x).ToList();

        existingLiquidLevels = allNotes.Where(n => n.Insulation != null && !string.IsNullOrWhiteSpace(n.Insulation.LiquidLevel))
            .Select(n => n.Insulation!.LiquidLevel!).Distinct().OrderBy(x => x).ToList();
    }

    private async Task HandleSubmit()
    {
        // HH:MM形式で時間を解析（秒は00で固定）
        if (!string.IsNullOrWhiteSpace(growthStartTimeStr))
        {
            if (TimeSpan.TryParseExact(growthStartTimeStr, @"hh\:mm", null, out var gts))
            {
                newItem.Parameters!.GrowthStartTime = gts;
            }
            else if (TimeSpan.TryParseExact(growthStartTimeStr, @"h\:mm", null, out var gts2))
            {
                newItem.Parameters!.GrowthStartTime = gts2;
            }
        }

        if (!string.IsNullOrWhiteSpace(shoulderEndTimeStr))
        {
            if (TimeSpan.TryParseExact(shoulderEndTimeStr, @"hh\:mm", null, out var sets))
            {
                newItem.Parameters!.ShoulderEndTime = sets;
            }
            else if (TimeSpan.TryParseExact(shoulderEndTimeStr, @"h\:mm", null, out var sets2))
            {
                newItem.Parameters!.ShoulderEndTime = sets2;
            }
        }

        newItem.CreatedAt = DateTime.UtcNow;
        try
        {
            Logger.LogInformation("Saving GrowthNote (Mobile): {item}", JsonSerializer.Serialize(newItem));
        }
        catch { }

        using (var db = DbFactory.CreateDbContext())
        {
            db.GrowthNotes.Add(newItem);
            await db.SaveChangesAsync();

            try
            {
                var saved = await db.GrowthNotes.AsNoTracking()
                    .Include(n => n.Parameters)
                    .Include(n => n.Insulation)
                    .FirstOrDefaultAsync(n => n.CGNoteId == newItem.CGNoteId);
                Logger.LogInformation("Saved from DB (Mobile): {item}", JsonSerializer.Serialize(saved));
            }
            catch { }
        }

        Navigation.NavigateTo("/growth-note-v2");
    }

