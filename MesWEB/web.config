<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <remove name="aspNetCore" />
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath="dotnet" arguments=".\MesWEB.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="InProcess" />
    <!-- Safari 対応: HTTP/2 設定 -->
    <httpProtocol>
      <customHeaders>
        <!-- キープアライブを無効化して接続タイムアウトを回避 -->
        <add name="Connection" value="keep-alive" />
        <!-- CORS ヘッダー：Safari で必要 -->
        <add name="Access-Control-Allow-Origin" value="*" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, OPTIONS" />
        <add name="Access-Control-Allow-Headers" value="Content-Type, Authorization" />
      </customHeaders>
    </httpProtocol>
    <!-- 静的ファイルのキャッシュ制御（IIS互換の属性に変更） -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00" />
      <!-- もしくは拡張ヘッダー指定:
           <clientCache cacheControlMode="UseCacheExtensions" cacheControlCustom="public, max-age=86400" /> -->
    </staticContent>
    <!-- リクエストフィルター：タイムアウト拡張 -->
    <security>
      <requestFiltering>
        <requestLimits maxUrl="4096" maxQueryString="2048" />
      </requestFiltering>
    </security>
  </system.webServer>
  <!-- system.net セクションを削除（IIS web.config では無効・0x8007000d の原因） -->
</configuration>