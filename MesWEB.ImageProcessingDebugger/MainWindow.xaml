<Window x:Class="MesWEB.ImageProcessingDebugger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Processing Debugger" Height="800" Width="1200">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Vertical" Margin="5">
            <Button Name="BtnLoad" Content="Load Image" Width="120" Margin="0,0,0,8" Click="BtnLoad_Click" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="CLAHE ClipLimit:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Slider Name="SldClahe" Minimum="1" Maximum="10" Value="2" Width="140" />
                <TextBlock Text="Adaptive BlockSize:" VerticalAlignment="Center" Margin="16,0,8,0" />
                <Slider Name="SldBlock" Minimum="3" Maximum="51" Value="15" Width="140" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <CheckBox Name="ChkDeskew" Content="Enable Deskew" IsChecked="True" Margin="0,0,16,0" />
                <CheckBox Name="ChkPerspective" Content="Enable Perspective" IsChecked="True" />
            </StackPanel>

            <Button Name="BtnProcess" Content="Process" Width="120" Click="BtnProcess_Click" />

            <Separator Margin="0,12" />
            <TextBlock Text="Original" FontWeight="Bold" />
            <Image Name="ImgOriginal" Stretch="Uniform" Height="300" Margin="0,4" />

            <TextBlock Text="Deskewed" FontWeight="Bold" />
            <Image Name="ImgDeskew" Stretch="Uniform" Height="200" Margin="0,4" />

            <TextBlock Text="Final Preprocessed" FontWeight="Bold" />
            <Image Name="ImgFinal" Stretch="Uniform" Height="200" Margin="0,4" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Vertical" Margin="12,0,0,0">
            <TextBlock Text="Debug Images" FontWeight="Bold" />
            <ListBox Name="LstDebug" Height="600" Margin="0,8,0,0" SelectionChanged="LstDebug_SelectionChanged" />
            <Button Name="BtnSave" Content="Save Selected" Width="120" Click="BtnSave_Click" />
        </StackPanel>
    </Grid>
</Window>